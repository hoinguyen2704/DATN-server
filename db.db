-- comment on database postgres is 'default administrative connection database';

grant connect, create, temporary on database hozitech_db to dev;

CREATE TABLE public.banners (
  id uuid NOT NULL PRIMARY KEY,
  created_at TIMESTAMP(6) NOT NULL,
  created_by VARCHAR(255),
  updated_at TIMESTAMP(6),
  updated_by VARCHAR(255),
  image_url VARCHAR(1000) NOT NULL,
  is_active BOOLEAN NOT NULL,
  sort_order INTEGER NOT NULL,
  target_url VARCHAR(1000),
  title VARCHAR(255)
);

ALTER TABLE public.banners owner TO dev;

CREATE TABLE public.brands (
  id uuid NOT NULL PRIMARY KEY,
  created_at TIMESTAMP(6) NOT NULL,
  created_by VARCHAR(255),
  updated_at TIMESTAMP(6),
  updated_by VARCHAR(255),
  logo_url VARCHAR(500),
  name VARCHAR(255) NOT NULL,
  slug VARCHAR(255) NOT NULL CONSTRAINT idx_brand_slug UNIQUE
);

ALTER TABLE public.brands owner TO dev;

CREATE TABLE public.categories (
  id uuid NOT NULL PRIMARY KEY,
  created_at TIMESTAMP(6) NOT NULL,
  created_by VARCHAR(255),
  updated_at TIMESTAMP(6),
  updated_by VARCHAR(255),
  description TEXT,
  image_url VARCHAR(500),
  name VARCHAR(100) NOT NULL,
  slug VARCHAR(150) NOT NULL CONSTRAINT ukoul14ho7bctbefv8jywp5v3i2 UNIQUE,
  sort_order INTEGER,
  status BOOLEAN NOT NULL,
  parent_id uuid CONSTRAINT fksaok720gsu4u2wrgbk10b5n8d REFERENCES public.categories
);

ALTER TABLE public.categories owner TO dev;

CREATE TABLE public.coupons (
  id uuid NOT NULL PRIMARY KEY,
  created_at TIMESTAMP(6) NOT NULL,
  created_by VARCHAR(255),
  updated_at TIMESTAMP(6),
  updated_by VARCHAR(255),
  code VARCHAR(50) NOT NULL CONSTRAINT idx_coupon_code UNIQUE,
  discount_type VARCHAR(50) NOT NULL,
  discount_value NUMERIC(15, 2),
  end_date TIMESTAMP(6),
  max_discount_amount NUMERIC(15, 2),
  min_order_value NUMERIC(15, 2),
  start_date TIMESTAMP(6),
  status VARCHAR(50) NOT NULL,
  usage_limit INTEGER CONSTRAINT coupons_usage_limit_check CHECK (usage_limit >= 0),
  used_count INTEGER NOT NULL CONSTRAINT coupons_used_count_check CHECK (used_count >= 0)
);

ALTER TABLE public.coupons owner TO dev;

CREATE TABLE public.flash_sales (
  id uuid NOT NULL PRIMARY KEY,
  created_at TIMESTAMP(6) NOT NULL,
  created_by VARCHAR(255),
  updated_at TIMESTAMP(6),
  updated_by VARCHAR(255),
  description TEXT,
  end_time TIMESTAMP(6) NOT NULL,
  name VARCHAR(200) NOT NULL,
  start_time TIMESTAMP(6) NOT NULL,
  status VARCHAR(20) NOT NULL
);

ALTER TABLE public.flash_sales owner TO dev;

CREATE TABLE public.otp_tokens (
  id uuid NOT NULL PRIMARY KEY,
  created_at TIMESTAMP(6) NOT NULL,
  created_by VARCHAR(255),
  updated_at TIMESTAMP(6),
  updated_by VARCHAR(255),
  email VARCHAR(150) NOT NULL,
  expires_at TIMESTAMP(6) NOT NULL,
  is_used BOOLEAN NOT NULL,
  otp_code VARCHAR(10) NOT NULL
);

ALTER TABLE public.otp_tokens owner TO dev;

CREATE INDEX idx_otp_email ON public.otp_tokens (email);

CREATE TABLE public.products (
  id uuid NOT NULL PRIMARY KEY,
  created_at TIMESTAMP(6) NOT NULL,
  created_by VARCHAR(255),
  updated_at TIMESTAMP(6),
  updated_by VARCHAR(255),
  description TEXT,
  is_featured BOOLEAN NOT NULL,
  name VARCHAR(250) NOT NULL,
  origin_price NUMERIC(15, 2) NOT NULL,
  slug VARCHAR(300) NOT NULL CONSTRAINT ukostq1ec3toafnjok09y9l7dox UNIQUE,
  specs_json JSONB,
  status VARCHAR(50),
  brand_id uuid CONSTRAINT fka3a4mpsfdf4d2y6r8ra3sc8mv REFERENCES public.brands,
  category_id uuid NOT NULL CONSTRAINT fkog2rp4qthbtt2lfyhfo32lsw9 REFERENCES public.categories
);

ALTER TABLE public.products owner TO dev;

CREATE TABLE public.product_variants (
  id uuid NOT NULL PRIMARY KEY,
  created_at TIMESTAMP(6) NOT NULL,
  created_by VARCHAR(255),
  updated_at TIMESTAMP(6),
  updated_by VARCHAR(255),
  status BOOLEAN NOT NULL,
  capacity VARCHAR(50),
  color VARCHAR(50),
  compare_at_price NUMERIC(15, 2),
  price NUMERIC(15, 2) NOT NULL,
  sku VARCHAR(50) NOT NULL CONSTRAINT ukq935p2d1pbjm39n0063ghnfgn UNIQUE,
  stock_quantity INTEGER NOT NULL CONSTRAINT product_variants_stock_quantity_check CHECK (stock_quantity >= 0),
  variant_name VARCHAR(255) NOT NULL,
  product_id uuid NOT NULL CONSTRAINT fkosqitn4s405cynmhb87lkvuau REFERENCES public.products
);

ALTER TABLE public.product_variants owner TO dev;

CREATE TABLE public.flash_sale_items (
  id uuid NOT NULL PRIMARY KEY,
  created_at TIMESTAMP(6) NOT NULL,
  created_by VARCHAR(255),
  updated_at TIMESTAMP(6),
  updated_by VARCHAR(255),
  flash_price NUMERIC(15, 2) NOT NULL,
  flash_stock INTEGER NOT NULL CONSTRAINT flash_sale_items_flash_stock_check CHECK (flash_stock >= 0),
  sold_count INTEGER NOT NULL CONSTRAINT flash_sale_items_sold_count_check CHECK (sold_count >= 0),
  flash_sale_id uuid NOT NULL CONSTRAINT fkmr5agn0eu29xqqog30yspa3e3 REFERENCES public.flash_sales,
  variant_id uuid NOT NULL CONSTRAINT fk86yyoqeiisx1rsodorhrao4bt REFERENCES public.product_variants,
  CONSTRAINT uklwt8dokmghq1nn0xksm9ck217 UNIQUE (flash_sale_id, variant_id)
);

ALTER TABLE public.flash_sale_items owner TO dev;

CREATE TABLE public.product_images (
  id uuid NOT NULL PRIMARY KEY,
  created_at TIMESTAMP(6) NOT NULL,
  created_by VARCHAR(255),
  updated_at TIMESTAMP(6),
  updated_by VARCHAR(255),
  alt_text VARCHAR(255),
  image_url VARCHAR(500) NOT NULL,
  is_primary BOOLEAN NOT NULL,
  sort_order INTEGER NOT NULL,
  product_id uuid NOT NULL CONSTRAINT fkqnq71xsohugpqwf3c9gxmsuy REFERENCES public.products,
  variant_id uuid CONSTRAINT fkqnqjv00ocaxfmu2k6b99ycdad REFERENCES public.product_variants
);

ALTER TABLE public.product_images owner TO dev;

CREATE INDEX idx_product_slug ON public.products (slug);

CREATE INDEX idx_product_category ON public.products (category_id);

CREATE INDEX idx_product_brand ON public.products (brand_id);

CREATE TABLE public.roles (
  id VARCHAR(50) NOT NULL PRIMARY KEY CONSTRAINT roles_id_check CHECK (
    (id)::TEXT = ANY (
      (
        ARRAY[
          'ADMIN'::CHARACTER VARYING,
          'USER'::CHARACTER VARYING,
          'SHIPPER'::CHARACTER VARYING
        ]
      )::TEXT[]
    )
  ),
  role_name VARCHAR(50) NOT NULL
);

ALTER TABLE public.roles owner TO dev;

CREATE TABLE public.system_configs (
  id uuid NOT NULL PRIMARY KEY,
  created_at TIMESTAMP(6) NOT NULL,
  created_by VARCHAR(255),
  updated_at TIMESTAMP(6),
  updated_by VARCHAR(255),
  config_key VARCHAR(100) NOT NULL CONSTRAINT idx_config_key UNIQUE,
  config_value VARCHAR(500),
  description VARCHAR(255)
);

ALTER TABLE public.system_configs owner TO dev;

CREATE TABLE public.users (
  id uuid NOT NULL PRIMARY KEY,
  created_at TIMESTAMP(6) NOT NULL,
  created_by VARCHAR(255),
  updated_at TIMESTAMP(6),
  updated_by VARCHAR(255),
  auth_provider VARCHAR(50),
  avatar_url VARCHAR(500),
  date_of_birth date,
  email VARCHAR(150) NOT NULL CONSTRAINT uk6dotkott2kjsp8vw4d0m25fb7 UNIQUE,
  full_name VARCHAR(100) NOT NULL,
  gender VARCHAR(10),
  password_hash VARCHAR(255),
  phone_number VARCHAR(15) CONSTRAINT uk9q63snka3mdh91as4io72espi UNIQUE,
  status VARCHAR(50),
  user_name VARCHAR(50) NOT NULL CONSTRAINT ukk8d0f2n7n88w1a16yhua64onx UNIQUE,
  role_id VARCHAR(50) NOT NULL CONSTRAINT fkp56c1712k691lhsyewcssf40f REFERENCES public.roles
);

ALTER TABLE public.users owner TO dev;

CREATE TABLE public.addresses (
  id uuid NOT NULL PRIMARY KEY,
  created_at TIMESTAMP(6) NOT NULL,
  created_by VARCHAR(255),
  updated_at TIMESTAMP(6),
  updated_by VARCHAR(255),
  detail_address VARCHAR(255) NOT NULL,
  district VARCHAR(100) NOT NULL,
  full_name VARCHAR(100) NOT NULL,
  is_default BOOLEAN NOT NULL,
  phone_number VARCHAR(15) NOT NULL,
  province VARCHAR(100) NOT NULL,
  ward VARCHAR(100) NOT NULL,
  user_id uuid NOT NULL CONSTRAINT fk1fa36y2oqhao3wgg2rw1pi459 REFERENCES public.users
);

ALTER TABLE public.addresses owner TO dev;

CREATE TABLE public.articles (
  id uuid NOT NULL PRIMARY KEY,
  created_at TIMESTAMP(6) NOT NULL,
  created_by VARCHAR(255),
  updated_at TIMESTAMP(6),
  updated_by VARCHAR(255),
  content TEXT NOT NULL,
  is_published BOOLEAN NOT NULL,
  slug VARCHAR(500) NOT NULL CONSTRAINT idx_article_slug UNIQUE,
  thumbnail_url VARCHAR(1000),
  title VARCHAR(500) NOT NULL,
  author_id uuid NOT NULL CONSTRAINT fke02fs2ut6qqoabfhj325wcjul REFERENCES public.users
);

ALTER TABLE public.articles owner TO dev;

CREATE TABLE public.carts (
  id uuid NOT NULL PRIMARY KEY,
  created_at TIMESTAMP(6) NOT NULL,
  created_by VARCHAR(255),
  updated_at TIMESTAMP(6),
  updated_by VARCHAR(255),
  quantity INTEGER NOT NULL CONSTRAINT carts_quantity_check CHECK (quantity >= 1),
  user_id uuid NOT NULL CONSTRAINT fkb5o626f86h46m4s7ms6ginnop REFERENCES public.users,
  variant_id uuid NOT NULL CONSTRAINT fkjampd70fsaueu2sxjmxep7nf7 REFERENCES public.product_variants,
  CONSTRAINT uk1ong1mrcmrpmh4mfqx7n85nxb UNIQUE (user_id, variant_id)
);

ALTER TABLE public.carts owner TO dev;

CREATE TABLE public.orders (
  id uuid NOT NULL PRIMARY KEY,
  created_at TIMESTAMP(6) NOT NULL,
  created_by VARCHAR(255),
  updated_at TIMESTAMP(6),
  updated_by VARCHAR(255),
  coupon_code VARCHAR(50),
  discount_amount NUMERIC(15, 2) NOT NULL,
  note VARCHAR(500),
  order_number VARCHAR(30) NOT NULL CONSTRAINT uknthkiu7pgmnqnu86i2jyoe2v7 UNIQUE,
  order_status VARCHAR(20) NOT NULL CONSTRAINT orders_order_status_check CHECK (
    (order_status)::TEXT = ANY (
      (
        ARRAY[
          'PENDING'::CHARACTER VARYING,
          'CONFIRMED'::CHARACTER VARYING,
          'PROCESSING'::CHARACTER VARYING,
          'SHIPPING'::CHARACTER VARYING,
          'SHIPPED'::CHARACTER VARYING,
          'CANCELLED'::CHARACTER VARYING,
          'RETURNED'::CHARACTER VARYING
        ]
      )::TEXT[]
    )
  ),
  payment_method VARCHAR(20) NOT NULL CONSTRAINT orders_payment_method_check CHECK (
    (payment_method)::TEXT = ANY (
      (
        ARRAY[
          'COD'::CHARACTER VARYING,
          'VNPAY'::CHARACTER VARYING,
          'MOMO'::CHARACTER VARYING,
          'BANK_TRANSFER'::CHARACTER VARYING
        ]
      )::TEXT[]
    )
  ),
  payment_status VARCHAR(20) NOT NULL CONSTRAINT orders_payment_status_check CHECK (
    (payment_status)::TEXT = ANY (
      (
        ARRAY[
          'PENDING'::CHARACTER VARYING,
          'COMPLETED'::CHARACTER VARYING,
          'FAILED'::CHARACTER VARYING,
          'REFUNDED'::CHARACTER VARYING
        ]
      )::TEXT[]
    )
  ),
  shipping_address_json JSONB,
  shipping_fee NUMERIC(15, 2) NOT NULL,
  subtotal NUMERIC(15, 2) NOT NULL,
  total_amount NUMERIC(15, 2) NOT NULL,
  user_id uuid NOT NULL CONSTRAINT fk32ql8ubntj5uh44ph9659tiih REFERENCES public.users
);

ALTER TABLE public.orders owner TO dev;

CREATE TABLE public.feedbacks (
  id uuid NOT NULL PRIMARY KEY,
  created_at TIMESTAMP(6) NOT NULL,
  created_by VARCHAR(255),
  updated_at TIMESTAMP(6),
  updated_by VARCHAR(255),
  admin_reply TEXT,
  content TEXT,
  images_json JSONB,
  rating INTEGER NOT NULL CONSTRAINT feedbacks_rating_check CHECK (
    (rating <= 5)
    AND (rating >= 1)
  ),
  replied_at TIMESTAMP(6),
  status VARCHAR(50) NOT NULL,
  order_id uuid CONSTRAINT fkbdhoov2mv332ks2m84owt5tv3 REFERENCES public.orders,
  product_id uuid NOT NULL CONSTRAINT fkti2ywtwc29ys1i591rmmaveyc REFERENCES public.products,
  user_id uuid NOT NULL CONSTRAINT fk312drfl5lquu37mu4trk8jkwx REFERENCES public.users
);

ALTER TABLE public.feedbacks owner TO dev;

CREATE INDEX idx_feedback_product ON public.feedbacks (product_id);

CREATE INDEX idx_feedback_user ON public.feedbacks (user_id);

CREATE TABLE public.notifications (
  id uuid NOT NULL PRIMARY KEY,
  created_at TIMESTAMP(6) NOT NULL,
  created_by VARCHAR(255),
  updated_at TIMESTAMP(6),
  updated_by VARCHAR(255),
  content TEXT NOT NULL,
  is_read BOOLEAN NOT NULL,
  title VARCHAR(200) NOT NULL,
  type VARCHAR(50),
  order_id uuid CONSTRAINT fk6og1jgdhfyqm6mk8v6a1qxias REFERENCES public.orders,
  user_id uuid NOT NULL CONSTRAINT fk9y21adhxn0ayjhfocscqox7bh REFERENCES public.users
);

ALTER TABLE public.notifications owner TO dev;

CREATE INDEX idx_notification_user ON public.notifications (user_id);

CREATE INDEX idx_notification_read ON public.notifications (is_read);

CREATE TABLE public.order_items (
  id uuid NOT NULL PRIMARY KEY,
  created_at TIMESTAMP(6) NOT NULL,
  created_by VARCHAR(255),
  updated_at TIMESTAMP(6),
  updated_by VARCHAR(255),
  product_name VARCHAR(250) NOT NULL,
  quantity INTEGER NOT NULL CONSTRAINT order_items_quantity_check CHECK (quantity >= 1),
  subtotal NUMERIC(15, 2) NOT NULL,
  unit_price NUMERIC(15, 2) NOT NULL,
  variant_name VARCHAR(150),
  order_id uuid NOT NULL CONSTRAINT fkbioxgbv59vetrxe0ejfubep1w REFERENCES public.orders,
  variant_id uuid NOT NULL CONSTRAINT fkemq71edpbn9wsxnxncfn1algp REFERENCES public.product_variants
);

ALTER TABLE public.order_items owner TO dev;

CREATE TABLE public.order_status_history (
  id uuid NOT NULL PRIMARY KEY,
  created_at TIMESTAMP(6) NOT NULL,
  created_by VARCHAR(255),
  updated_at TIMESTAMP(6),
  updated_by VARCHAR(255),
  description VARCHAR(255),
  status VARCHAR(20) NOT NULL CONSTRAINT order_status_history_status_check CHECK (
    (status)::TEXT = ANY (
      (
        ARRAY[
          'PENDING'::CHARACTER VARYING,
          'CONFIRMED'::CHARACTER VARYING,
          'PROCESSING'::CHARACTER VARYING,
          'SHIPPING'::CHARACTER VARYING,
          'SHIPPED'::CHARACTER VARYING,
          'CANCELLED'::CHARACTER VARYING,
          'RETURNED'::CHARACTER VARYING
        ]
      )::TEXT[]
    )
  ),
  order_id uuid NOT NULL CONSTRAINT fknmcbg3mmbt8wfva97ra40nmp3 REFERENCES public.orders
);

ALTER TABLE public.order_status_history owner TO dev;

CREATE INDEX idx_order_history_order_id ON public.order_status_history (order_id);

CREATE INDEX idx_order_user ON public.orders (user_id);

CREATE INDEX idx_order_status ON public.orders (order_status);

CREATE INDEX idx_order_number ON public.orders (order_number);

CREATE TABLE public.tickets (
  id uuid NOT NULL PRIMARY KEY,
  created_at TIMESTAMP(6) NOT NULL,
  created_by VARCHAR(255),
  updated_at TIMESTAMP(6),
  updated_by VARCHAR(255),
  status VARCHAR(50) NOT NULL,
  subject VARCHAR(255) NOT NULL,
  ticket_number VARCHAR(50) NOT NULL CONSTRAINT idx_ticket_number UNIQUE,
  user_id uuid NOT NULL CONSTRAINT fk4eqsebpimnjen0q46ja6fl2hl REFERENCES public.users
);

ALTER TABLE public.tickets owner TO dev;

CREATE TABLE public.ticket_messages (
  id uuid NOT NULL PRIMARY KEY,
  created_at TIMESTAMP(6) NOT NULL,
  created_by VARCHAR(255),
  updated_at TIMESTAMP(6),
  updated_by VARCHAR(255),
  attachments_json JSONB,
  content TEXT NOT NULL,
  sender_type VARCHAR(50) NOT NULL,
  ticket_id uuid NOT NULL CONSTRAINT fk8c9vw45c3j5m6arnwp4c3iaby REFERENCES public.tickets
);

ALTER TABLE public.ticket_messages owner TO dev;

CREATE INDEX idx_ticket_message_ticket ON public.ticket_messages (ticket_id);

CREATE INDEX idx_ticket_user ON public.tickets (user_id);

CREATE TABLE public.tokens (
  id uuid NOT NULL PRIMARY KEY,
  created_at TIMESTAMP(6) NOT NULL,
  expiration_date TIMESTAMP(6) NOT NULL,
  expired BOOLEAN NOT NULL,
  revoked BOOLEAN NOT NULL,
  token VARCHAR(500) NOT NULL CONSTRAINT ukna3v9f8s7ucnj16tylrs822qj UNIQUE,
  token_type VARCHAR(50) NOT NULL,
  user_id uuid NOT NULL CONSTRAINT fk2dylsfo39lgjyqml2tbe0b0ss REFERENCES public.users
);

ALTER TABLE public.tokens owner TO dev;

CREATE INDEX idx_token_user ON public.tokens (user_id);

CREATE TABLE public.wishlists (
  id uuid NOT NULL PRIMARY KEY,
  created_at TIMESTAMP(6) NOT NULL,
  created_by VARCHAR(255),
  updated_at TIMESTAMP(6),
  updated_by VARCHAR(255),
  product_id uuid NOT NULL CONSTRAINT fkl7ao98u2bm8nijc1rv4jobcrx REFERENCES public.products,
  user_id uuid NOT NULL CONSTRAINT fk330pyw2el06fn5g28ypyljt16 REFERENCES public.users,
  CONSTRAINT uk_user_product_wishlist UNIQUE (user_id, product_id)
);

ALTER TABLE public.wishlists owner TO dev;

