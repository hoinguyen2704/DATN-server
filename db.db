-- we don't know how to generate root <with-no-name> (class Root) :(

comment on database postgres is 'default administrative connection database';

grant connect, create, temporary on database hozitechdb to dev;

create table categories
(
    id          uuid         not null
        primary key,
    created_at  timestamp(6) not null,
    created_by  varchar(255),
    updated_at  timestamp(6),
    updated_by  varchar(255),
    active      boolean      not null,
    description text,
    image_url   varchar(500),
    name        varchar(100) not null,
    slug        varchar(150) not null
        constraint ukoul14ho7bctbefv8jywp5v3i2
            unique,
    parent_id   uuid
        constraint fksaok720gsu4u2wrgbk10b5n8d
            references categories
);

alter table categories
    owner to dev;

create table coupons
(
    id               uuid         not null
        primary key,
    created_at       timestamp(6) not null,
    created_by       varchar(255),
    updated_at       timestamp(6),
    updated_by       varchar(255),
    active           boolean      not null,
    code             varchar(50)  not null
        constraint ukeplt0kkm9yf2of2lnx6c1oy9b
            unique,
    description      varchar(255),
    discount_percent double precision,
    discount_value   numeric(15, 2),
    expiration_date  timestamp(6) not null,
    max_discount     numeric(15, 2),
    min_order_value  numeric(15, 2),
    quantity         integer      not null
        constraint coupons_quantity_check
            check (quantity >= 0),
    used_count       integer      not null
        constraint coupons_used_count_check
            check (used_count >= 0)
);

alter table coupons
    owner to dev;

create table products
(
    id          uuid           not null
        primary key,
    created_at  timestamp(6)   not null,
    created_by  varchar(255),
    updated_at  timestamp(6),
    updated_by  varchar(255),
    active      boolean        not null,
    base_price  numeric(15, 2) not null,
    brand       varchar(100),
    deleted     boolean        not null,
    description text,
    name        varchar(250)   not null,
    slug        varchar(300)   not null
        constraint ukostq1ec3toafnjok09y9l7dox
            unique,
    weight      double precision,
    category_id uuid           not null
        constraint fkog2rp4qthbtt2lfyhfo32lsw9
            references categories
);

alter table products
    owner to dev;

create table product_images
(
    id         uuid         not null
        primary key,
    created_at timestamp(6) not null,
    created_by varchar(255),
    updated_at timestamp(6),
    updated_by varchar(255),
    alt_text   varchar(255),
    image_url  varchar(500) not null,
    is_primary boolean      not null,
    sort_order integer      not null,
    product_id uuid         not null
        constraint fkqnq71xsohugpqwf3c9gxmsuy
            references products
);

alter table product_images
    owner to dev;

create table product_variants
(
    id               uuid           not null
        primary key,
    created_at       timestamp(6)   not null,
    created_by       varchar(255),
    updated_at       timestamp(6),
    updated_by       varchar(255),
    active           boolean        not null,
    compare_at_price numeric(15, 2),
    price            numeric(15, 2) not null,
    sku              varchar(50)    not null
        constraint ukq935p2d1pbjm39n0063ghnfgn
            unique,
    stock            integer        not null
        constraint product_variants_stock_check
            check (stock >= 0),
    variant_name     varchar(150)   not null,
    product_id       uuid           not null
        constraint fkosqitn4s405cynmhb87lkvuau
            references products
);

alter table product_variants
    owner to dev;

create index idx_product_slug
    on products (slug);

create index idx_product_category
    on products (category_id);

create index idx_product_brand
    on products (brand);

create table roles
(
    id        varchar(50) not null
        primary key
        constraint roles_id_check
            check ((id)::text = ANY
                   ((ARRAY ['ADMIN'::character varying, 'USER'::character varying, 'SHIPPER'::character varying])::text[])),
    role_name varchar(50) not null
);

alter table roles
    owner to dev;

create table users
(
    id            uuid         not null
        primary key,
    created_at    timestamp(6) not null,
    created_by    varchar(255),
    updated_at    timestamp(6),
    updated_by    varchar(255),
    avatar_url    varchar(500),
    date_of_birth date,
    deleted       boolean      not null,
    email         varchar(150) not null
        constraint uk6dotkott2kjsp8vw4d0m25fb7
            unique,
    full_name     varchar(100) not null,
    gender        varchar(10),
    password      varchar(255) not null,
    phone_number  varchar(15)
        constraint uk9q63snka3mdh91as4io72espi
            unique,
    user_name     varchar(50)  not null
        constraint ukk8d0f2n7n88w1a16yhua64onx
            unique,
    role_id       varchar(50)  not null
        constraint fkp56c1712k691lhsyewcssf40f
            references roles
);

alter table users
    owner to dev;

create table addresses
(
    id             uuid         not null
        primary key,
    created_at     timestamp(6) not null,
    created_by     varchar(255),
    updated_at     timestamp(6),
    updated_by     varchar(255),
    detail_address varchar(255) not null,
    district       varchar(100) not null,
    full_name      varchar(100) not null,
    is_default     boolean      not null,
    phone_number   varchar(15)  not null,
    province       varchar(100) not null,
    ward           varchar(100) not null,
    user_id        uuid         not null
        constraint fk1fa36y2oqhao3wgg2rw1pi459
            references users
);

alter table addresses
    owner to dev;

create table carts
(
    id         uuid         not null
        primary key,
    created_at timestamp(6) not null,
    created_by varchar(255),
    updated_at timestamp(6),
    updated_by varchar(255),
    quantity   integer      not null
        constraint carts_quantity_check
            check (quantity >= 1),
    user_id    uuid         not null
        constraint fkb5o626f86h46m4s7ms6ginnop
            references users,
    variant_id uuid         not null
        constraint fkjampd70fsaueu2sxjmxep7nf7
            references product_variants,
    constraint uk1ong1mrcmrpmh4mfqx7n85nxb
        unique (user_id, variant_id)
);

alter table carts
    owner to dev;

create table orders
(
    id               uuid           not null
        primary key,
    created_at       timestamp(6)   not null,
    created_by       varchar(255),
    updated_at       timestamp(6),
    updated_by       varchar(255),
    cancel_reason    varchar(500),
    discount_amount  numeric(15, 2) not null,
    full_name        varchar(100)   not null,
    note             varchar(500),
    order_number     varchar(30)    not null
        constraint uknthkiu7pgmnqnu86i2jyoe2v7
            unique,
    payment_method   varchar(20)    not null
        constraint orders_payment_method_check
            check ((payment_method)::text = ANY
                   ((ARRAY ['COD'::character varying, 'VNPAY'::character varying, 'MOMO'::character varying, 'BANK_TRANSFER'::character varying])::text[])),
    phone_number     varchar(15)    not null,
    shipping_address varchar(500)   not null,
    shipping_fee     numeric(15, 2) not null,
    status           varchar(20)    not null
        constraint orders_status_check
            check ((status)::text = ANY
                   ((ARRAY ['PENDING'::character varying, 'CONFIRMED'::character varying, 'PROCESSING'::character varying, 'SHIPPING'::character varying, 'SHIPPED'::character varying, 'CANCELLED'::character varying, 'RETURNED'::character varying])::text[])),
    subtotal         numeric(15, 2) not null,
    total_amount     numeric(15, 2) not null,
    tracking_number  varchar(100),
    coupon_id        uuid
        constraint fkn1d1gkxckw648m2n2d5gx0yx5
            references coupons,
    user_id          uuid           not null
        constraint fk32ql8ubntj5uh44ph9659tiih
            references users
);

alter table orders
    owner to dev;

create table feedbacks
(
    id         uuid         not null
        primary key,
    created_at timestamp(6) not null,
    created_by varchar(255),
    updated_at timestamp(6),
    updated_by varchar(255),
    content    text,
    image_urls text,
    replied_at timestamp(6),
    reply      text,
    star       integer      not null
        constraint feedbacks_star_check
            check ((star <= 5) AND (star >= 1)),
    order_id   uuid
        constraint fkbdhoov2mv332ks2m84owt5tv3
            references orders,
    product_id uuid         not null
        constraint fkti2ywtwc29ys1i591rmmaveyc
            references products,
    user_id    uuid         not null
        constraint fk312drfl5lquu37mu4trk8jkwx
            references users
);

alter table feedbacks
    owner to dev;

create index idx_feedback_product
    on feedbacks (product_id);

create index idx_feedback_user
    on feedbacks (user_id);

create table notifications
(
    id         uuid         not null
        primary key,
    created_at timestamp(6) not null,
    created_by varchar(255),
    updated_at timestamp(6),
    updated_by varchar(255),
    content    text         not null,
    is_read    boolean      not null,
    title      varchar(200) not null,
    type       varchar(50),
    order_id   uuid
        constraint fk6og1jgdhfyqm6mk8v6a1qxias
            references orders,
    user_id    uuid         not null
        constraint fk9y21adhxn0ayjhfocscqox7bh
            references users
);

alter table notifications
    owner to dev;

create index idx_notification_user
    on notifications (user_id);

create index idx_notification_read
    on notifications (is_read);

create table order_details
(
    id           uuid           not null
        primary key,
    created_at   timestamp(6)   not null,
    created_by   varchar(255),
    updated_at   timestamp(6),
    updated_by   varchar(255),
    product_name varchar(250)   not null,
    quantity     integer        not null
        constraint order_details_quantity_check
            check (quantity >= 1),
    total_price  numeric(15, 2) not null,
    unit_price   numeric(15, 2) not null,
    variant_name varchar(150),
    order_id     uuid           not null
        constraint fkjyu2qbqt8gnvno9oe9j2s2ldk
            references orders,
    variant_id   uuid           not null
        constraint fk63mqrfva3vf2gx2sublm4m51w
            references product_variants
);

alter table order_details
    owner to dev;

create index idx_order_user
    on orders (user_id);

create index idx_order_status
    on orders (status);

create index idx_order_number
    on orders (order_number);

create table payments
(
    id             uuid           not null
        primary key,
    created_at     timestamp(6)   not null,
    created_by     varchar(255),
    updated_at     timestamp(6),
    updated_by     varchar(255),
    amount         numeric(15, 2) not null,
    method         varchar(20)    not null
        constraint payments_method_check
            check ((method)::text = ANY
                   ((ARRAY ['COD'::character varying, 'VNPAY'::character varying, 'MOMO'::character varying, 'BANK_TRANSFER'::character varying])::text[])),
    note           varchar(500),
    paid_at        timestamp(6),
    status         varchar(20)    not null
        constraint payments_status_check
            check ((status)::text = ANY
                   ((ARRAY ['PENDING'::character varying, 'COMPLETED'::character varying, 'FAILED'::character varying, 'REFUNDED'::character varying])::text[])),
    transaction_id varchar(100),
    order_id       uuid           not null
        constraint fk81gagumt0r8y3rmudcgpbk42l
            references orders
);

alter table payments
    owner to dev;

create index idx_payment_order
    on payments (order_id);

create index idx_payment_transaction
    on payments (transaction_id);

create table tokens
(
    id              uuid         not null
        primary key,
    created_at      timestamp(6) not null,
    expiration_date timestamp(6) not null,
    expired         boolean      not null,
    revoked         boolean      not null,
    token           varchar(500) not null
        constraint ukna3v9f8s7ucnj16tylrs822qj
            unique,
    token_type      varchar(50)  not null,
    user_id         uuid         not null
        constraint fk2dylsfo39lgjyqml2tbe0b0ss
            references users
);

alter table tokens
    owner to dev;

create index idx_token_user
    on tokens (user_id);

